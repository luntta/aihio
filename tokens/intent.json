      "intent": {
        "overlay-scrim": {
          "$value": "0 0 0 / 0.8",
          "$type": "color",
          "$description": "Modal backdrop scrim behind blocking overlays."
        }
      }
    },
    "radius": {
      "intent": {
        "surface": {
          "$value": "{radius.lg}",
          "$type": "dimension",
          "$description": "Corner radius for cards, alerts, and other framed surfaces."
        },
        "interactive": {
          "$value": "{radius.md}",
