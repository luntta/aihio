{
  "name": "aihio",
  "version": "2.0.0",
  "description": "AI-first design system built on native web components. Zero dependencies.",
  "type": "module",
  "main": "./dist/aihio.js",
  "exports": {
    ".": "./dist/aihio.js",
    "./components": "./dist/components.js",
    "./css": "./dist/aihio.css",
    "./schema": "./dist/schema.json"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "tokens": "node src/tokens/build.js",
    "styles": "node src/schema/build.js && node src/css/build.js",
    "schema": "node src/schema/build.js",
    "dev": "node dev.js",
    "build": "node build.js",
    "test": "node --test",
    "check": "npm run build && npm test",
    "prepare": "npm run build"
  },
  "repository": "git+https://github.com/luntta/aihio.git",
  "keywords": [
    "design-system",
    "web-components",
    "ai-first",
    "design-tokens",
    "ui",
    "components",
    "zero-dependency"
  ],
  "author": "Raine Luntta <raine.luntta@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/luntta/aihio/issues"
  },
  "homepage": "https://github.com/luntta/aihio#readme",
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
