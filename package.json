{
  "name": "aihio",
  "version": "2.0.0",
  "description": "AI-first design system built on native web components. Zero dependencies.",
  "type": "module",
  "main": "./dist/aihio.js",
  "types": "./dist/aihio.d.ts",
  "bin": {
    "aihio-lint": "dist/aihio-lint.js",
    "aihio-mcp": "dist/aihio-mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/aihio.d.ts",
      "default": "./dist/aihio.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    },
    "./prompt": {
      "types": "./dist/prompt.d.ts",
      "default": "./dist/prompt.js"
    },
    "./lint": {
      "types": "./dist/lint.d.ts",
      "default": "./dist/lint.js"
    },
    "./css": "./dist/aihio.css",
    "./schema": "./dist/schema.json"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "tokens": "node src/tokens/build.js",
    "styles": "node src/schema/build.js && node src/css/build.js",
    "schema": "node src/schema/build.js",
    "dev": "node dev.js",
    "build": "node build.js",
    "test": "npm run build && node --test",
    "check": "npm test",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luntta/aihio.git"
  },
  "keywords": [
    "design-system",
    "web-components",
    "ai-first",
    "design-tokens",
    "ui",
    "components",
    "zero-dependency"
  ],
  "author": "Raine Luntta <raine.luntta@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/luntta/aihio/issues"
  },
  "homepage": "https://github.com/luntta/aihio#readme",
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
